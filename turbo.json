{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "generate": {
            "dependsOn": ["^generate"],
            "outputs": ["generated/**"]
        },
        "build": {
            "dependsOn": ["^build", "^generate"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**", "generated/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "test": {
            "dependsOn": ["^test"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
