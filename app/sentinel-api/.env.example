# ORM
# DATABASE_URL: Use Prisma Accelerate or Transaction Pooler (Port 6543)
DATABASE_URL="prisma://accelerate.prisma-data.net/..."
# DIRECT_URL: Use Direct Connection (Port 5432) for Migrations. Encode special characters (e.g., @ -> %40)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Database
SUPABASE_URL="https://[PROJECT-ID].supabase.co"
SUPABASE_ANON_KEY="[ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"

# JWT
SUPABASE_JWT_SECRET="token"
SUPABASE_JWT_ALGORITHM="token"
SUPABASE_JWT="token"

# URLs
CLIENT_WEB_URL="localhost:port"
ADMIN_WEB_URL="localhost:port"