# ORM
DATABASE_URL="prisma://accelerate.prisma-data.net/..."
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Database
SUPABASE_URL="https://[PROJECT-ID].supabase.co"
SUPABASE_ANON_KEY="[ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"

# Support Account
SUPPORT_ACCOUNT_EMAIL="support@sentinelph.tech"
SUPPORT_ACCOUNT_PASSWORD="[SET-A-LOCAL-ONLY-PASSWORD]"

# JWT
SUPABASE_JWT_SECRET="token"
SUPABASE_JWT_ALGORITHM="token"
SUPABASE_JWT="token"

# URLs
NEXT_PUBLIC_SUPPORT_URL=http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CORE_URL=http://localhost:3002
SUPABASE_PASSAGE_IMAGE_BUCKET=PASSAGE_IMAGE_BUCKET
# Production reference:
# NEXT_PUBLIC_SUPPORT_URL=https://support.sentinelph.tech
# NEXT_PUBLIC_APP_URL=https://app.sentinelph.tech
# NEXT_PUBLIC_CORE_URL=https://core.sentinelph.tech

# SMTP
RESEND_HOST=[RESEND-HOST]
RESEND_PORT=[RESEND-PORT]
RESEND_USERNAME=resend
RESEND_PASSWORD=[RESEND-PASSWORD]

# Gemini API
GEMINI_API_KEY=[GEMINI-API-KEY]
GEMINI_PROJECT_ID=[GEMINI-PROJECT-ID]

# Redis
REDIS_URL=rediss://default:[REDIS-PASSWORD]@[REDIS-HOST]:[REDIS-PORT]
REDIS_PUBLIC_ENDPOINT=[REDIS-HOST]:[REDIS-PORT]

# PDF Documents / Worker
# Mode: Set to 'sync' for local development (no Redis polling overhead). Set to 'redis' for background processing.
PDF_GENERATION_MODE=sync
# Required production values unless noted otherwise.
PDF_ARTIFACTS_BUCKET=sentinel-pdf-artifacts

PDF_ASSETS_BUCKET=sentinel-pdf-assets
PDF_GENERATION_QUEUE_NAME=pdf-generation
PDF_WORKER_CONCURRENCY=2
PDF_GLOBAL_CONCURRENCY=2
PDF_JOB_ATTEMPTS=3
PDF_JOB_BACKOFF_MS=5000
PDF_JOB_TIMEOUT_MS=120000
PDF_SIGNED_URL_TTL_SECONDS=300
ANALYTICS_REPORT_RETENTION_DAYS=7
PDF_MAX_REPORT_RANGE_DAYS=366
# Safe local default; tune from load testing before production rollout.
PDF_MAX_ARTIFACT_BYTES=15728640

# Telemetry Queue (BullMQ) / CRON Flush / Batch Buffer (Redis List)
# Required for high-throughput proctoring events.
# Set to 'redis' or 'async' to enable BullMQ-backed ingestion; defaults to 'sync'.
# When using 'redis' in production, a separate telemetry worker process must also be running.
# Local development should prefer 'sync' unless Redis and the worker are both available.
TELEMETRY_INGESTION_MODE=redis
TELEMETRY_REDIS_QUEUE_NAME=telemetry-ingestion
TELEMETRY_REDIS_JOB_NAME=append-proctoring-event
TELEMETRY_REDIS_BUFFER_NAME=[REDIS-BUFFER-NAME]
TELEMETRY_INGESTION_WORKER_CONCURRENCY=5
TELEMETRY_INGESTION_ATTEMPTS=3
TELEMETRY_INGESTION_BACKOFF_MS=1000
TELEMETRY_INGESTION_KEEP_COMPLETED=1000
TELEMETRY_INGESTION_KEEP_FAILED=5000
# Secret token to authorize internal cron flushes. 
# Must match the Bearer token in the cron trigger headers.
TELEMETRY_CRON_SECRET=[SECURE-RANDOM-TOKEN]
CRON_SECRET=[SECURE-RANDOM-TOKEN]

# Managed LiveKit Cloud / Live Inspection
# Disabled by default; keep this false or unset unless the managed LiveKit service is configured.
# Server-only values. Do not add NEXT_PUBLIC_LIVEKIT_* variables, AWS variables, recording, or Egress credentials.
LIVE_INSPECTION_ENABLED=false
# Comma-separated institution UUID allowlist. Empty means no production institution can use live inspection.
LIVE_INSPECTION_INSTITUTION_ALLOWLIST=
LIVEKIT_URL=wss://[PROJECT].livekit.cloud
LIVEKIT_API_KEY=[LIVEKIT-API-KEY]
LIVEKIT_API_SECRET=[LIVEKIT-API-SECRET]
LIVEKIT_REQUEST_TIMEOUT_MS=20000
LIVEKIT_VIEWER_JOIN_TIMEOUT_MS=15000
LIVEKIT_MAX_INSPECTION_DURATION_SECONDS=300
LIVEKIT_TOKEN_TTL_SECONDS=60
LIVEKIT_ROOM_EMPTY_TIMEOUT_SECONDS=30
LIVEKIT_ROOM_DEPARTURE_TIMEOUT_SECONDS=10
LIVEKIT_GLOBAL_ACTIVE_INSPECTION_LIMIT=20
LIVEKIT_INSTITUTION_ACTIVE_INSPECTION_LIMIT=10
# Opt-in only; set true in a dedicated non-production LiveKit project to run provider smoke tests.
LIVEKIT_SMOKE_TEST_ENABLED=false

# Expo
EXPO_PUBLIC_API_URL=[API-URL]
