{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "baseUrl": ".",
        "paths": {
            "@sentinel/db": ["../../packages/db/src"],
            "@sentinel/db/*": ["../../packages/db/src/*"],
            "@sentinel/shared": ["../../packages/shared/src"],
            "@sentinel/shared/*": ["../../packages/shared/src/*"]
        },
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "types": ["node"]
    },
    "include": ["src/**/*", "generated/**/*", "prisma.config.ts"],
    "exclude": ["node_modules"]
}
