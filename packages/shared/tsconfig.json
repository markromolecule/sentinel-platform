{
    "compilerOptions": {
        "target": "ES2019",
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "CommonJS",
        "moduleResolution": "node",
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "esModuleInterop": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx"
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
