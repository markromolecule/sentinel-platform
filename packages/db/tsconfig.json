{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": ["es2022", "DOM"],
        "types": ["node"]
    },
    "include": ["src/**/*", "generated/**/*"],
    "exclude": ["node_modules", "dist"]
}
