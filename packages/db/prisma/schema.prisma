generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["partialIndexes"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

generator kysely {
  provider        = "prisma-kysely"
  output          = "../src/generated"
  previewFeatures = ["partialIndexes"]
  fileName        = "types.ts"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

