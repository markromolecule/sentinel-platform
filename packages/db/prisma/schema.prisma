generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["partialIndexes"]
  engineType      = "library"
}

generator kysely {
  provider        = "prisma-kysely"
  output          = "../src/generated"
  previewFeatures = ["partialIndexes"]
  fileName        = "types.ts"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

