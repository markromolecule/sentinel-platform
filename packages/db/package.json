{
    "name": "@sentinel/db",
    "version": "1.0.0",
    "description": "Shared Database schema and types",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "generate": "prisma generate",
        "migrate:deploy": "prisma migrate deploy",
        "build": "tsup src/index.ts --format cjs,esm --external \"../generated/client\" && tsc --emitDeclarationOnly",
        "dev": "tsup src/index.ts --format cjs,esm --external \"../generated/client\" --watch",
        "postinstall": "prisma generate",
        "lint": "eslint src/",
        "test": "vitest run"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "~7.5.0",
        "@prisma/client-runtime-utils": "~7.5.0",
        "@prisma/config": "~7.5.0",
        "@prisma/extension-accelerate": "^3.0.1",
        "kysely": "^0.28.12",
        "pg": "^8.20.0",
        "prisma-extension-kysely": "^4.0.0",
        "prisma-kysely": "^3.1.0"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/pg": "^8.11.11",
        "dotenv": "^16.4.7",
        "prisma": "~7.5.0",
        "tsup": "^8.3.6",
        "typescript": "^7.0.2",
        "vitest": "^4.0.18"
    }
}
