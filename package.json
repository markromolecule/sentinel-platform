{
    "name": "sentinel",
    "version": "0.0.0",
    "private": true,
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "model:yamnet": "./scripts/convert-yamnet-model.sh",
        "db:migrate": "pnpm --dir packages/db run migrate:deploy",
        "db:seed:support": "pnpm --dir app/sentinel-api run seed:support",
        "db:setup:support": "pnpm run db:migrate && pnpm run db:seed:support",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "clean": "rm -rf node_modules"
    },
    "devDependencies": {
        "@types/react": "~19.2.17",
        "prettier": "latest",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "turbo": "latest",
        "typescript": "~5.9.2"
    },
    "dependencies": {
        "expo": "^57.0.7",
        "pg": "^8.19.0"
    }
}
