{
    "name": "sentinel",
    "version": "0.0.0",
    "private": true,
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "clean": "rm -rf node_modules"
    },
    "devDependencies": {
        "@types/react": "~19.2.14",
        "prettier": "latest",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "turbo": "latest",
        "typescript": "~5.9.2"
    },
    "dependencies": {
        "expo": "^55.0.8",
        "pg": "^8.19.0"
    },
    "pnpm": {
        "overrides": {
            "@prisma/client-runtime-utils": "7.5.0",
            "@types/pg": "8.11.11",
            "@types/react": "19.2.14",
            "@types/react-dom": "19.1.11"
        },
        "onlyBuiltDependencies": [
            "@prisma/engines",
            "prisma"
        ]
    }
}
